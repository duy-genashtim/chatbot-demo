# ================================================================
# chatbotv2 backend — .env.example
# Copy to .env and fill in real values. chmod 600 .env after writing.
# DO NOT commit .env to git.
# ================================================================

# ----------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_FORMAT=pretty

# ----------------------------------------------------------------
# SERVER
# ----------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------
DATABASE_URL=sqlite:///./data/chatbotv2.db

# ----------------------------------------------------------------
# MICROSOFT ENTRA ID (AUTH)
# ----------------------------------------------------------------
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/callback/microsoft-entra-id
DEFAULT_ADMIN_EMAIL=admin@company.com

# ----------------------------------------------------------------
# GEMINI API
# ----------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-3.1-flash-lite-preview
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=800

# ----------------------------------------------------------------
# RAG / EMBEDDING
# ----------------------------------------------------------------
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHROMA_PATH=./data/chroma
TOP_K_VECTOR=5
TOP_K_FINAL=3

# ----------------------------------------------------------------
# SESSIONS & CACHE
# ----------------------------------------------------------------
SESSION_TTL_SEC=1800
MAX_SESSIONS=500
CACHE_TTL_SEC=1800

# ----------------------------------------------------------------
# CHAT HISTORY
# ----------------------------------------------------------------
HISTORY_RETENTION_DAYS=90
HISTORY_REHYDRATE_TURNS=20

# ----------------------------------------------------------------
# RATE LIMITS
# ----------------------------------------------------------------
RATE_LIMIT_EXTERNAL_PER_MIN=10
RATE_LIMIT_INTERNAL_PER_MIN=60
ANONYMOUS_SHOW_SOURCES=true

# ----------------------------------------------------------------
# UPLOADS
# ----------------------------------------------------------------
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_TYPES=pdf

# ----------------------------------------------------------------
# NEXTAUTH
# ----------------------------------------------------------------
NEXTAUTH_SECRET=<32-plus-byte-random-hex>
NEXTAUTH_URL=http://localhost:3000

# ----------------------------------------------------------------
# DEV-ONLY: Fake auth bypass for E2E / Playwright tests
# WARNING: NEVER set this in production — the app will refuse to
# start if FAKE_AUTH_EMAIL is set and ENVIRONMENT=prod.
# When set (dev only), ALL auth checks are bypassed and this email
# is returned as the authenticated user. Remove before deploying.
# ----------------------------------------------------------------
# FAKE_AUTH_EMAIL=dev@test.com
