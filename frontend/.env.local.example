# chatbotv2 frontend — .env.local.example
# Copy to .env.local and fill in real values.
# DO NOT commit .env.local to git.

NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BRAND_NAME=G-HelpDesk
NEXT_PUBLIC_BRAND_COLOR=#253956

# NextAuth (server-only — not exposed to browser)
AZURE_AD_TENANT_ID=<same as backend AZURE_TENANT_ID>
AZURE_AD_CLIENT_ID=<same as backend AZURE_CLIENT_ID>
AZURE_AD_CLIENT_SECRET=<same as backend AZURE_CLIENT_SECRET>
NEXTAUTH_SECRET=<same as backend NEXTAUTH_SECRET>
NEXTAUTH_URL=http://localhost:3000
